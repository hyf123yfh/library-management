DATABASE_URL="file:./prisma/dev.db"
PORT=3001
AUTH_SECRET="change-this-secret-before-production"
LIBRARIAN_JWT_SECRET="change-this-librarian-secret-before-production"

# 前端地址（支付完成后回跳）
FRONTEND_URL="http://localhost:5173"
ALIPAY_NOTIFY_URL="https://xxxx.ngrok-free.app/api/reader/alipay-notify"
# return_url 会自动用 notify 同域名的 /api/reader/alipay-return（沙箱不接受 localhost）
# 由于.env文件不提交到git，且每人的地址不一样，运行时请手动修改.env文件和URL地址，并将自己的ngrok地址复制上去
# 如我的代码中是这样：ALIPAY_NOTIFY_URL="https://embezzle-art-pellet.ngrok-free.dev/api/reader/alipay-notify"

# 邮件服务配置 - 用于图书到期提醒功能
# 支持 Gmail, QQ邮箱, 企业邮箱等带有SMTP功能的邮箱服务
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
# 注意：
# 1. Gmail用户需要生成应用专用密码：https://support.google.com/accounts/answer/185833
# 2. QQ邮箱SMTP_HOST="smtp.qq.com", SMTP_PORT="587"
# 3. 企业邮箱按具体配置填写

# 图书到期提醒定时任务配置
# REMINDER_CRON_TIME: cron 表达式，定义定时任务执行时间
#   - "0 8 * * *"    = 每天早上 8:00
#   - "0 0 * * *"    = 每天午夜 0:00
#   - "0 */6 * * *"  = 每 6 小时执行一次
#   - "*/30 * * * *" = 每 30 分钟执行一次
REMINDER_CRON_TIME="0 8 * * *"

# 是否在启动时立即执行一次提醒检查（用于测试）
# 设置为 "true" 会在服务器启动时执行一次提醒任务
RUN_REMINDER_ON_START="false"
